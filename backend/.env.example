# Copy to .env and fill in. NEVER commit real keys.

# --- VLM providers (two configured per the risk table) ---
# Leave both blank to run in MOCK_MODE (serves the frozen mock payload).
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Force mock mode even if keys are present (useful for the demo).
# MOCK_MODE=1

# --- Storage / assets ---
# DATA_DIR=./var/audits
# ARTIFACTS_DIR=./var/artifacts

# --- Studio link built into PR comments ---
STUDIO_BASE_URL=http://localhost:5173

# --- VLM budget ---
REQUEST_TIMEOUT_S=45
MAX_RETRIES=2

# --- CORS (Studio dev server) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
